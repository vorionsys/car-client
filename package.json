{
  "name": "@vorionsys/car-client",
  "version": "1.0.1",
  "description": "CAR (Categorical Agentic Registry) Client SDK -- Agent identity, provenance, and governance operations",
  "keywords": [
    "car",
    "agent",
    "trust",
    "governance",
    "phase6",
    "vorion",
    "ai-governance",
    "categorical-agentic-registry"
  ],
  "license": "Apache-2.0",
  "author": "Vorion LLC",
  "homepage": "https://vorion.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vorionsys/car-client.git"
  },
  "bugs": {
    "url": "https://github.com/vorionsys/car-client/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@vorionsys/shared-constants": "^2.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "pack:check": "npm pack --dry-run",
    "changeset:version": "changeset version && npm install --package-lock-only",
    "changeset:release": "changeset publish"
  }
}
